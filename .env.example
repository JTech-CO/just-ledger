# 복사해서 .env 로 쓴다. .env 는 커밋하지 않는다.
POSTGRES_PASSWORD=ledger
DATABASE_URL=postgres://ledger:ledger@localhost:5432/ledger

# web(Phoenix.Token 서명)과 realtime(검증)이 공유하는 키. 반드시 직접 생성해 넣는다
# (미설정 시 realtime 은 fail-closed 로 기동을 거절한다). 값은 커밋 금지.
#   생성: openssl rand -hex 64
SECRET_KEY_BASE=

# 환율 폴링(M3) — 실제 키는 커밋 금지
FX_API_URL=
FX_API_KEY=
